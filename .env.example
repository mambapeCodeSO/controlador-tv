# =====================================================================
# Controle-TV — variáveis de ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA versione o .env (já está no .gitignore).
# =====================================================================

# URL do projeto Supabase (ex.: https://xxxxx.supabase.co).
# Pública: exposta no navegador (prefixo PUBLIC_).
PUBLIC_SUPABASE_URL=

# Chave anônima (anon) do Supabase. Somente leitura via RLS.
# Pública: usada pelo player da TV no navegador.
PUBLIC_SUPABASE_ANON_KEY=

# Chave service role do Supabase. IGNORA o RLS — acesso total.
# SECRETA: use apenas no servidor. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Senha única de acesso ao painel /admin.
# SECRETA. Escolha uma senha forte.
ADMIN_PASSWORD=

# Segredo usado para assinar o cookie de sessão (HMAC-SHA256).
# SECRETA. Gere um valor aleatório longo, ex.: openssl rand -hex 32
SESSION_SECRET=
