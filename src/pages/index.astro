---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout title="Controle-TV — Console">
  <main class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-6 py-16 text-center">
    <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-xs text-muted">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full rounded-full bg-online opacity-75 motion-safe:animate-ping"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-online"></span>
      </span>
      console de sinalização
    </span>

    <h1 class="font-display text-4xl font-bold tracking-tight text-text sm:text-5xl">
      Controle-TV
    </h1>
    <p class="mt-4 max-w-md text-balance text-muted">
      Controle remotamente o que cada TV da empresa exibe. Cada painel abre uma
      rota fixa e você troca o conteúdo daqui — sem digitar URL na TV.
    </p>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row">
      <a
        href="/admin"
        class="rounded-lg bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-hover"
      >
        Abrir painel
      </a>
      <a
        href="/login"
        class="rounded-lg border border-border bg-surface px-6 py-3 font-medium text-text transition-colors hover:border-primary/60"
      >
        Entrar
      </a>
    </div>

    <p class="mt-10 font-mono text-xs text-muted">
      cada TV abre <span class="text-text">/tv/&lt;slug&gt;</span> em tela cheia
    </p>
  </main>
</BaseLayout>
